# Backend Configuration
BACKEND_MODE=mock
APP_NAME=Polymarket Paper Trading

# Frontend Configuration
API_URL=http://localhost:8000

# Optional
APP_NAME=Polymarket Paper Trading

# Backend auth (MVP)
# Used only when BACKEND_MODE=api and calling POST /auth/login
JWT_SECRET=change-me
DEMO_EMAIL=demo@example.com
DEMO_PASSWORD=demo-password
# PostgreSQL Database Configuration (Docker environment)
POSTGRES_DB=polymarket_db
POSTGRES_USER=polymarket_user
POSTGRES_PASSWORD=polymarket_password

# Database URL (generated from above variables in docker-compose.yml)
# DATABASE_URL=postgresql://polymarket_user:polymarket_password@db:5432/polymarket_db

# Optional AWS credentials for worker raw/transform pipeline
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_REGION=eu-west-3
# S3_RAW_BUCKET=
# S3_RAW_PREFIX=polymarket/raw

