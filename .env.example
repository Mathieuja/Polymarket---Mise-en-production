
# Backend Configuration
BACKEND_MODE=api
APP_NAME=Polymarket Paper Trading

# Frontend configuration
API_URL=http://localhost:8000

# Backend auth (MVP)
JWT_SECRET=change-me
DEMO_EMAIL=demo@example.com
DEMO_PASSWORD=demo-password

# PostgreSQL (Docker)
POSTGRES_DB=polymarket_db
POSTGRES_USER=polymarket_user
POSTGRES_PASSWORD=polymarket_password

# Worker / S3 pipeline
S3_RAW_BUCKET=...
S3_RAW_PREFIX=polymarket/raw
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_SESSION_TOKEN=...
AWS_ENDPOINT=minio.lab.sspcloud.fr
# Optional tuning
WORKER_CONSOLE_LOG_LEVEL=INFO
TRANSFORM_POLL_INTERVAL_SECONDS=20
TRANSFORM_BATCH_LIMIT=5

REDIS_HOST=redis

REDIS_PORT=6379

