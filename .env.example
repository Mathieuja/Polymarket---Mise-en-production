# Backend Configuration
BACKEND_MODE=mock
APP_NAME=Polymarket Paper Trading

# Frontend Configuration
API_URL=http://localhost:8000

# PostgreSQL Database Configuration (Docker environment)
POSTGRES_DB=polymarket_db
POSTGRES_USER=polymarket_user
POSTGRES_PASSWORD=polymarket_password

# Database URL (generated from above variables in docker-compose.yml)
# DATABASE_URL=postgresql://polymarket_user:polymarket_password@db:5432/polymarket_db

